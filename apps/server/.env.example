# Signs Better-Auth session cookies — min 32 chars, unique per environment.
# Generate one: openssl rand -base64 32 (see README → Environment Variables)
BETTER_AUTH_SECRET=GENERATE_A_SECRET
BETTER_AUTH_URL=http://localhost:3000
# The web app's origin, allowed by the API's CORS config
CORS_ORIGIN=http://localhost:3001

# Matches the local docker-compose postgres service (pnpm run db:start)
DATABASE_URL=postgresql://postgres:password@localhost:5432/weather-app

# Create one at https://home.openweathermap.org/api_keys — free tier is enough;
# new keys can take up to ~an hour to activate (401 from upstream until then)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
