{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "openapi:generate": "SKIP_ENV_VALIDATION=1 tsx src/scripts/generate-openapi.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.7.0",
    "@weather-app/auth": "workspace:*",
    "@weather-app/db": "workspace:*",
    "@weather-app/env": "workspace:*",
    "@weather-app/schemas": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "evlog": "catalog:",
    "fastify": "^5.3.3",
    "fastify-type-provider-zod": "^7.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@weather-app/config": "workspace:*",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "undici": "^6.27.0",
    "vitest": "^4.1.9"
  }
}
